#!/usr/bin/env bash
# Project pre-commit checks:
#   1. Reject authored_by = "ai" in ship-tracked TOMLs
#      (CLAUDE.md "Ship-mode narrative policy").
#   2. Verify DEVELOPER_NOTES.md dev-count sentinels against live code
#      (scripts/verify_dev_counts.py; see Task 1 in the
#      pre-ship cleanup session).
#
# Install by running: git config core.hooksPath .githooks
set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [[ -z "$STAGED" ]]; then
    exit 0
fi

# --- 1. Ship-mode narrative policy -----------------------------------

AI_FILES=""
while IFS= read -r f; do
    case "$f" in
        articles/*.toml|thresholds/*.toml)
            if grep -q '^authored_by = "ai"' "$f" 2>/dev/null; then
                AI_FILES="$AI_FILES$f"$'\n'
            fi
            ;;
    esac
done <<< "$STAGED"

if [[ -n "$AI_FILES" ]]; then
    echo "ERROR: AI-drafted prose in ship-tracked TOMLs:" >&2
    printf '  %s\n' $AI_FILES >&2
    echo >&2
    echo 'Policy: articles/ and thresholds/ must not carry' >&2
    echo '  authored_by = "ai"' >&2
    echo 'Either blank the field and let scripts/auto_gen_narrative.py' >&2
    echo 'populate it at render time, or human-author and set' >&2
    echo '  authored_by = "human" or "mixed".' >&2
    echo 'See docs/auto_gen_narrative_plan.md and CLAUDE.md' >&2
    echo '"Ship-mode narrative policy" for the full rule.' >&2
    exit 1
fi

# --- 2. Dev-count sentinel drift -------------------------------------

# Only run when DEVELOPER_NOTES.md or any derivation input is staged:
# keeps the hook fast for unrelated commits. Derivation inputs are the
# type chart (src/gopvpsim/moves.py) and the test suite (tests/**).
needs_dev_count_check=0
while IFS= read -r f; do
    case "$f" in
        DEVELOPER_NOTES.md|src/gopvpsim/moves.py|tests/*|scripts/verify_dev_counts.py)
            needs_dev_count_check=1
            ;;
    esac
done <<< "$STAGED"

if [[ "$needs_dev_count_check" -eq 1 ]]; then
    if ! python "$REPO_ROOT/scripts/verify_dev_counts.py" --quiet; then
        echo >&2
        echo 'Commit blocked by dev-count drift.' >&2
        exit 1
    fi
fi

exit 0
