{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Bash(direnv exec:*)",
      "Bash(python:*)",
      "Bash(.venv/bin/python:*)",
      "Bash(uv run:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(scripts/publish_website.sh:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sed:*)",
      "Bash(echo:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(curl:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/format_md.py --hook"
          }
        ]
      }
    ]
  }
}
